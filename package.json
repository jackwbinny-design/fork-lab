{
  "name": "fork-lab",
  "version": "0.1.0",
  "private": false,
  "description": "A GitHub fork learning dashboard demo built with React and Vite.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1",
    "update:data": "node scripts/update-github-data.js",
    "update:cache": "USE_CACHE=1 node scripts/update-github-data.js",
    "update:dashboard": "npm run update:data && npm run enrich:details && npm run enrich:readmes && npm run refine:categories && npm run build",
    "enrich:details": "node scripts/enrich-github-details.js",
    "enrich:readmes": "node scripts/enrich-readmes.js",
    "refine:categories": "node scripts/refine-categories.js",
    "delete:repo": "node scripts/delete-github-repo.js"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.2",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
